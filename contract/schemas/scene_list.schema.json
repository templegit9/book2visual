{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://book2visual/contract/scene_list.schema.json",
  "title": "SceneList",
  "description": "Text-stage output (LLM guided-JSON). Consumed by image + assembly stages. Internal to service/.",
  "type": "object",
  "additionalProperties": false,
  "required": ["characters", "scenes"],
  "properties": {
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "appearance_prompt", "ref_sheet_prompt"],
        "properties": {
          "name": { "type": "string" },
          "appearance_prompt": {
            "type": "string",
            "description": "Canonical appearance descriptors, appended to every panel prompt this character is in."
          },
          "ref_sheet_prompt": {
            "type": "string",
            "description": "Prompt for the single canonical reference image used by the consistency backend."
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "image_prompt", "characters_present", "caption", "pivotal"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "title": { "type": "string" },
          "image_prompt": { "type": "string" },
          "characters_present": { "type": "array", "items": { "type": "string" } },
          "caption": {
            "type": "string",
            "maxLength": 200,
            "description": "Author-voice prose burned into the panel caption box. Capped for legibility."
          },
          "pivotal": {
            "type": "boolean",
            "description": "If true, the scene gets a full-page 1x1 slot instead of a 2x2 quadrant."
          }
        }
      }
    }
  }
}
